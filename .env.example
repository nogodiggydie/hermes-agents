# Copy to .env (which is gitignored) and fill in real values.
# DO NOT commit the real .env. Commit only this .env.example.

# --- AWS (for the Hermes agent host) ---
# Prefer AWS SSO / instance profile; only use static keys for local dev.
AWS_REGION=us-east-2
AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- SSH bastion (only if you use one) ---
# BASTION_HOST=
# BASTION_USER=ubuntu

# --- LLM provider keys (server-side; laptop usually does not need these) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# --- Hermes agent runtime ---
HERMES_AGENT_REMOTE=ssh://aws   # matches the alias in ~/.ssh/config
HERMES_LOG_LEVEL=info

# --- Local dev flags ---
DEBUG=false
